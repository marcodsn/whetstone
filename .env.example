# Whetstone generator config — copy to `.env` and edit. Used only by the offline
# CLI (`npm run generate`); the app itself never reads this and never calls an
# LLM. Real shell env vars and --flags override anything set here.

# OpenAI-compatible endpoint. Defaults to ollama.
WHETSTONE_BASE_URL=http://localhost:11434/v1

# Model name as your endpoint expects it.
WHETSTONE_MODEL=qwen2.5:32b

# API key. Most local servers ignore it; "local" is a fine placeholder.
WHETSTONE_API_KEY=local

# Max number of existing prompts per domain shown to the model as "do not
# repeat". Dedup still rejects against the whole domain; this only bounds how
# much goes into the prompt so a large domain can't overflow the context.
WHETSTONE_AVOID_LIMIT=20
